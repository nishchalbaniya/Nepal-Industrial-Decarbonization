{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "pro/Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn nepal_decarb_pro.api:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "environments": {
    "production": {
      "variables": {
        "ENVIRONMENT": "production",
        "LOG_LEVEL": "info",
        "LLM_BACKEND": "stub",
        "TZ": "Asia/Kathmandu"
      }
    }
  }
}
